# ------------------------------------------------------------
# Device configuration
#
# Docker (Mac or any machine without NVIDIA):
#   SAMURAI_DEVICE=cpu
#
# Docker with NVIDIA GPU (linux/amd64):
#   SAMURAI_DEVICE=cuda
#   Run with: docker compose --profile gpu up
#
# Native run on Apple Silicon (outside Docker):
#   SAMURAI_DEVICE=mps
# ------------------------------------------------------------
SAMURAI_DEVICE=cpu

SAMURAI_MODEL_SIZE=base_plus
SAMURAI_DTYPE=bfloat16
SAMURAI_APP_ROOT=sam2
SAMURAI_DATA_PATH=data/uploads
SAMURAI_MAX_UPLOAD_DURATION_SEC=10.0
SAMURAI_SCORE_THRESH=0.0
SAMURAI_FFMPEG_THREADS=4
